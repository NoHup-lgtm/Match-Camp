# ── Servidor ────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080

# ── Banco de dados ───────────────────────────────────────────────────────────
# Local (docker/podman compose)
DATABASE_URL=postgres://matchcamp:matchcamp@localhost:5432/matchcamp?sslmode=disable
# Supabase (producao) - copie a "Connection string" do painel Transaction Pooler
# DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── Redis ────────────────────────────────────────────────────────────────────
# Local
REDIS_URL=redis://localhost:6379/0
# Upstash (producao) - copie a URL rediss:// do painel Upstash
# REDIS_URL=rediss://default:[token]@[host].upstash.io:6379
# REDIS_PASSWORD=   # so necessario se a URL nao incluir a senha
# REDIS_TLS=true    # habilitar para URLs rediss://

# ── Sessao / Auth ─────────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=matchcamp_session
SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_SECURE=true em producao (requer HTTPS)
ALLOWED_EMAIL_DOMAINS=
# Exemplo: "faculdade.edu.br,uni.br" — vazio = qualquer dominio

# ── CORS ──────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://app.matchcamp.com,https://www.matchcamp.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback
# Em producao: https://api.SEU_DOMINIO.com/v1/auth/google/callback

# ── Storage ───────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:8080
MAX_PROFILE_PHOTO_BYTES=5242880

STORAGE_DRIVER=local
# STORAGE_DRIVER=r2 em producao

# Cloudflare R2 (producao)
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# ── Compose local (dev only) ──────────────────────────────────────────────────
HTTP_HOST_PORT=8080
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
